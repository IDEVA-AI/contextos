# ContextOS — env de produção (docker stack)
# Copia pra .env.stack (gitignored) no servidor e preenche com valores reais.
# Path no servidor: /home/deploy/apps/contextos/.env.stack

# Database (role + db criados no infra_postgres compartilhado via scripts/setup-database.sql)
CONTEXTOS_DB_PASSWORD=__GERAR_SENHA_FORTE__

# Cookie session (32+ chars random). Gera com: openssl rand -base64 48
CONTEXTOS_SESSION_SECRET=__GERAR_32_CHARS__

# Embeddings — opcional. Sem ela cai pra fallback ILIKE (funciona menos preciso).
# Quando setar, embeddings entram automaticamente sem rebuild.
OPENAI_API_KEY=
EMBEDDING_PROVIDER=openai

# LLM provider — usa claude-bridge (proxy local pra sessão Claude Code do host)
# Default funciona se claude-bridge tiver rodando em 172.21.0.1:3200 (padrão IDEVA).
# Pra usar API key Anthropic/OpenAI no futuro: descomentar lib/llm-provider.ts e setar a key.
CLAUDE_BRIDGE_URL=http://172.21.0.1:3200/generate
CLAUDE_BRIDGE_MODEL=claude-sonnet

# Rate limit por minuto, por API key (Redis token bucket)
RATE_LIMIT_PER_MIN=100
