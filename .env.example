# ============================================
# ContextOS — environment variables
# ============================================
# Copie pra .env.local e preencha.
# Nunca commitar .env.local

# --- Database (dev local via docker-compose) ---
DATABASE_URL=postgres://contextos:contextos_dev@localhost:5432/contextos

# --- Redis (cache + queue) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
NEXTAUTH_SECRET=change_me_jwt_secret_at_least_32_chars_long
NEXTAUTH_URL=http://localhost:3000

# --- LLM Providers (pelo menos 1 obrigatório) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Embeddings (default: openai com text-embedding-3-small) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Storage (filesystem local no MVP) ---
STORAGE_DIR=./data/storage

# --- App ---
NODE_ENV=development
LOG_LEVEL=info
