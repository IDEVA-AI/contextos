{
  "name": "@contextos/cli",
  "version": "0.1.0",
  "description": "Command-line interface for ContextOS — manage workspaces, brains, memory, documents and compile context from your terminal.",
  "private": true,
  "type": "module",
  "bin": {
    "contextos": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
